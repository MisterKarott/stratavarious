{
  "name": "stratavarious",
  "version": "1.6.0",
  "description": "Persistent memory system for Claude Code — session consolidation, vault, and cross-session knowledge",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "bench": "node tests/bench.mjs",
    "lint": "npm run lint:js && npm run lint:sh",
    "lint:js": "eslint hooks/*.js tests/*.js",
    "lint:sh": "shellcheck scripts/*.sh",
    "lint:fix": "eslint hooks/*.js tests/*.js --fix",
    "validate": "npm run lint && npm run test"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1"
  },
  "files": [
    "hooks/",
    "scripts/",
    "skills/",
    "templates/",
    ".claude-plugin/"
  ],
  "license": "MIT"
}
